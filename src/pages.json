{
  "easycom": {
    "autoscan": true,
    "custom": {
      "my-(.*)": "@/components/my-$1/my-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "魔法工具屋",
        "navigationBarBackgroundColor": "#7c3aed",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/img2pdf/index",
      "style": {
        "navigationBarTitleText": "图片转PDF",
        "navigationBarBackgroundColor": "#7c3aed",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/pdf2img/index",
      "style": {
        "navigationBarTitleText": "PDF转图片",
        "navigationBarBackgroundColor": "#7c3aed",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/image-compress/index",
      "style": {
        "navigationBarTitleText": "图片压缩",
        "navigationBarBackgroundColor": "#7c3aed",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/merge-pdf/index",
      "style": {
        "navigationBarTitleText": "PDF合并",
        "navigationBarBackgroundColor": "#7c3aed",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/about/index",
      "style": {
        "navigationBarTitleText": "关于",
        "navigationBarBackgroundColor": "#7c3aed",
        "navigationBarTextStyle": "white"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "魔法工具屋",
    "navigationBarBackgroundColor": "#7c3aed",
    "backgroundColor": "#F5F6FA"
  }
}
