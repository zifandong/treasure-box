{
  "name": "百宝箱",
  "appid": "",
  "description": "实用工具小程序，图片转PDF、Word转PDF",
  "versionName": "1.0.0",
  "versionCode": "100",
  "transformPx": false,
  "h5": {
    "title": "百宝箱",
    "router": {
      "mode": "hash"
    },
    "devServer": {
      "port": 5173,
      "disableHostCheck": true,
      "proxy": {}
    },
    "optimization": {
      "treeShaking": {
        "enable": true
      }
    }
  },
  "mp-weixin": {
    "appid": "",
    "setting": {
      "urlCheck": false,
      "es6": true,
      "postcss": true,
      "minified": true
    },
    "usingComponents": true,
    "permission": {
      "scope.camera": {
        "desc": "用于拍照或选择图片"
      }
    },
    "requiredPrivateInfos": [
      "chooseMessageFile"
    ]
  }
}
